{
  "name": "filepacks",
  "description": "CLI for deterministic .fpk artifacts.",
  "version": "0.1.3",
  "author": "filepacks",
  "license": "Apache-2.0",
  "homepage": "https://github.com/robertonevarez/filepacks-oss/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/robertonevarez/filepacks-oss/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertonevarez/filepacks-oss.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "filepacks",
    "cli",
    "artifacts",
    "verification"
  ],
  "type": "module",
  "bin": {
    "filepacks": "bin/filepacks.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b && chmod +x bin/filepacks.js",
    "test": "npm run build && node --test \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "@filepacks/core": "0.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
