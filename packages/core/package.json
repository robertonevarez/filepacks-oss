{
  "name": "@filepacks/core",
  "description": "Reusable filepacks artifact packaging, verification, and comparison primitives.",
  "version": "0.1.0",
  "author": "filepacks",
  "license": "Apache-2.0",
  "homepage": "https://github.com/filepacks/filepacks/tree/main/packages/core",
  "keywords": [
    "filepacks",
    "artifacts",
    "packaging",
    "verification"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/filepacks/filepacks.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc -b",
    "clean": "node scripts/clean.mjs",
    "prepack": "npm run build",
    "test": "npm run build && node --test \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "tar-stream": "^3.1.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/tar-stream": "^3.1.4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
