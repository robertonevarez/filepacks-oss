            "/faq": {
              "type": "page",
              "filepath": "faq.mdx",
              "title": "FAQ"
            },
            "/troubleshooting": {
              "type": "page",
              "filepath": "troubleshooting.mdx",
              "title": "Troubleshooting"
            }
          }
        }
