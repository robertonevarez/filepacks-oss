{
  "scalar": "2.0.0",
  "$schema": "https://cdn.scalar.com/schema/scalar-config-next.json",
  "info": {
    "title": "Filepacks",
    "description": "Agent-ergonomic artifact infrastructure for portable, inspectable, comparable outputs"
  },
  "assetsDir": "assets",
  "logo": {
    "darkMode": "/logo-dark.svg",
    "lightMode": "/logo-light.svg"
  },
  "versions": {
    "default": {
