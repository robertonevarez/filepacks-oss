{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Filepacks",
  "theme": "mint",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#0D9488",
    "light": "#07C983",
    "dark": "#0D9488"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "navigation": {
    "anchors": [
      {
        "anchor": "GitHub",
        "icon": "github",
        "href": "https://github.com/robertonevarez/filepacks-oss"
