{
  "$schema": "https://mintlify.com/docs.json",
  "name": "filepacks",
  "theme": "mint",
  "description": "filepacks creates portable, inspectable artifacts for agent workflows, evals, and regression comparisons.",
  "logo": {
    "dark": "public/logo-dark.svg",
    "light": "public/logo-light.svg",
    "href": "https://www.filepacks.com/"
  },
  "favicon": {
    "light": "public/favicon.svg",
    "dark": "public/favicon-dark.svg"
  },
  "colors": {
    "primary": "#000000",
    "light": "#FFFFFF",
    "dark": "#000000"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "icons": {
    "library": "lucide"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/robertonevarez/filepacks-oss"
        },
        {
          "anchor": "Quickstart",
          "icon": "book",
          "href": "/quickstart"
        }
      ]
    },
    "groups": [
      {
        "group": "Introduction",
        "pages": [
          "index",
          "quickstart",
          "installation",
          "why-filepacks",
          "concepts",
          "diffing"
        ]
      },
      {
        "group": "Artifacts",
        "pages": [
          "artifacts",
          "artifacts/format",
          "artifacts/manifest",
          "artifacts/determinism"
        ]
      },
      {
        "group": "CLI",
        "pages": [
          "cli",
          "cli/pack",
          "cli/inspect",
          "cli/verify",
          "cli/compare"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "ci-cd-integration",
          "faq",
          "troubleshooting"
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/robertonevarez/filepacks-oss"
    }
  },
  "navbar": {
    "links": []
  }
}
