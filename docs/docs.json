{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Filepacks",
  "theme": "mint",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.ico",
