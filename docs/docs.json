        "pages": [
          "artifacts",
          "artifacts/format",
          "artifacts/manifest",
          "artifacts/determinism"
        ]
      },
      {
        "group": "CLI",
        "pages": [
          "cli",
          "cli/pack",
          "cli/inspect",
          "cli/verify",
          "cli/compare"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "ci-cd-integration",
          "faq",
          "troubleshooting"
        ]
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/robertonevarez/filepacks-oss"
  }
